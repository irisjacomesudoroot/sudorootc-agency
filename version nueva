/* --- 1. VARIABLES GLOBALES --- */
:root {
    --bg-dark: #050505;
    --text-main: #ffffff;
    --text-muted: #888888;
    --neon-green: #76b947;
    --neon-purple: #7B2EFF;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Montserrat', sans-serif;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    overflow-x: hidden;
    background-image: radial-gradient(circle at 50% 20%, #2a2a2a 0%, #050505 55%, #000000 100%);
    min-height: 100vh;
}

/* --- 2. ESTRUCTURA PRINCIPAL Y NAVEGACIÓN --- */
.main-container {
    width: calc(100% - 60px); 
    margin: 0; 
    padding-bottom: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.side-nav {
    position: fixed;
    right: 0;
    top: 0;
    height: 100vh;
    width: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    z-index: 100;
}

.side-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.side-nav a {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 2px;
    transition: color 0.3s;
}

.side-nav a:hover {
    color: var(--neon-purple);
}

/* --- 3. LOGO SUPERIOR IZQUIERDO --- */
.top-left-logo {
    position: absolute;
    top: 30px;
    left: 40px;
    display: flex;
    align-items: center;
    gap: 15px;
    z-index: 100;
}

.top-left-logo img {
    width: 45px;
    filter: drop-shadow(0px 5px 10px rgba(0,0,0,0.8));
}

.logo-text-mini {
    font-size: 0.8rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 2px;
}

.logo-text-mini span {
    color: var(--neon-green);
    font-size: 0.7rem;
    font-weight: 800;
}

/* --- 4. HERO SECTION (INICIO) --- */
.hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    max-width: 800px;
    padding-top: 50px;
    margin: 0 auto;
}

.cat-logo {
    width: 220px;
    margin-bottom: 20px;
    filter: drop-shadow(0px 10px 20px rgba(0,0,0,0.8));
}

.agency-title {
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: 2px;
    line-height: 1.1;
    margin-bottom: 30px;
}

.highlight-green {
    color: var(--neon-green);
    font-size: 2.5rem;
    font-weight: 800;
}

.main-hook {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-muted);
    line-height: 1.3;
    margin-bottom: 15px;
}

.sub-hook {
    font-size: 1rem;
    color: #888888;
    margin-bottom: 40px;
}

.cta-button {
    padding: 15px 40px;
    background-color: var(--neon-green);
    color: #000;
    text-decoration: none;
    font-weight: 800;
    font-size: 1.1rem;
    border-radius: 5px;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px rgba(118, 185, 71, 0.2);
}

.cta-button:hover {
    background-color: #52b022;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(118, 185, 71, 0.4);
}

/* --- BOTÓN LEARN MORE GENERAL --- */
.learn-more {
    color: var(--neon-purple) !important;
    font-size: 0.85rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: none; 
    letter-spacing: 1px;
    margin-top: auto; 
    display: inline-block;
    transition: color 0.3s ease;
}

.learn-more:hover {
    color: #ffffff !important;
}

/* --- 5. SECCIÓN DE SERVICIOS (GRID DE 4 - TARJETAS VERTICALES) --- */
.services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); 
    gap: 25px;
    padding: 0 5%;
    max-width: 1300px;
    margin: 0 auto 60px auto;
    width: 100%;
}

.service-card {
    background-color: #1a1a1a;
    border-radius: 15px;
    height: 480px; /* Estas se mantienen altas como en tu diseño */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-size: cover;
    background-position: center;
    overflow: hidden;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(118, 185, 71, 0.2);
}

.service-card .card-text-area {
    background: linear-gradient(to top, rgba(10,10,10,0.95) 50%, rgba(10,10,10,0.6) 80%, transparent);
    padding: 30px 25px 25px 25px;
    height: 50%;
    width: 100%;
    display: flex;
    flex-direction: column;
}

.service-card h3 {
    color: var(--neon-green);
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 10px;
    text-transform: uppercase;
    line-height: 1.2;
}

.service-card p {
    color: #cccccc;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 20px;
}

/* --- 5.1 SEGUNDO BLOQUE ESTRATEGIAS (GRID DE 3 - CUADRADOS 800x800) --- */
.section-title-center {
    text-align: center;
    color: #ffffff;
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: 3px;
    margin-top: 60px;
    margin-bottom: 40px;
    text-transform: uppercase;
    opacity: 0.9;
    width: 100%;
}

.strategy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); 
    gap: 30px;
    padding: 0 5%;
    max-width: 1250px; 
    margin: 0 auto 100px auto;
    width: 100%;
}

.strategy-card {
    background-color: #1a1a1a;
    border-radius: 15px;
    aspect-ratio: 1 / 1; /* Forzamos el cuadrado 800x800 */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-size: cover;
    background-position: center top;
    overflow: hidden;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.strategy-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(118, 185, 71, 0.2);
}

.strategy-card .card-text-area {
    background: transparent; 
    height: 50%; /* Ocupa exactamente la mitad de abajo */
    padding: 10px 25px 20px 25px; /* Ajuste milimétrico para que no se corte */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
}

.strategy-card h3 {
    color: var(--neon-green);
    font-size: 1rem; 
    font-weight: 800;
    margin-bottom: 5px; 
    text-transform: uppercase;
    line-height: 1.2;
}

.strategy-card h3 .muted {
    color: var(--text-muted);
}

.strategy-card p {
    color: #cccccc;
    font-size: 0.75rem; 
    line-height: 1.4;
    margin-bottom: 10px; 
}

/* --- 6. BANNER GIGANTES (PLATEADO) --- */
.banner-gigantes {
    position: relative; 
    width: 90%;
    max-width: 1100px;
    margin: 80px auto 120px auto;
    background-image: url('banner.png'); 
    background-size: cover;
    background-position: center;
    border-radius: 15px;
