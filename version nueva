}

.logo-text-plata {
    font-size: 1.2rem;
    font-weight: 900;
    color: #333333;
    letter-spacing: 1px;
    opacity: 0.8;
}

.metal-cat {
    position: absolute;
    bottom: -50px; 
    left: 50%;
    transform: translateX(-50%); 
    width: 120px; 
    filter: drop-shadow(0px 15px 20px rgba(0,0,0,0.8)); 
    transition: transform 0.3s ease;
}

.metal-cat:hover {
    transform: translateX(-50%) scale(1.05); 
}

/* --- 7. ANIMACIONES Y RESPONSIVO --- */
.fade-in { animation: fadeIn 1.2s ease-out forwards; }
.fade-in-delay { animation: fadeIn 1.5s ease-out forwards; animation-delay: 0.3s; opacity: 0; }

@keyframes fadeIn {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
}

@media (max-width: 1100px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); } 
    .strategy-grid { grid-template-columns: repeat(2, 1fr); }
    .banner-gigantes { padding: 40px 30px 60px 30px; }
}

@media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; } 
    .strategy-grid { grid-template-columns: 1fr; }
    .main-container { width: 100%; margin-right: 0; } 
    .side-nav { display: none; } 
    .agency-title { font-size: 2.5rem; }
    .trusted-logos { gap: 30px; }
}
